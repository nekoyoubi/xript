	// --- Boot -------------------------------------------------------------------

	let animId = 0;
	let canvasW = 0;
	let canvasH = 0;
	let currentSim: Simulation | null = null;
	let bgCanvas: HTMLCanvasElement | null = null;

	function addConsole(text: string, level: "log" | "error") {
		const el = document.getElementById("hero-console")!;
		const placeholder = el.querySelector(".hero-placeholder");
		if (placeholder) placeholder.remove();

		const line = document.createElement("div");
		line.className = `hero-console-line ${level}`;
		const prefix = level === "error" ? "[error] " : "[log] ";
		line.textContent = `${prefix}${text}`;
		el.appendChild(line);
		el.scrollTop = el.scrollHeight;
	}

	function clearConsole() {
		const el = document.getElementById("hero-console")!;
		const hint = currentSim?.apiHint || "";
		el.innerHTML = hint
			? `<div class="hero-api-hint"><div class="hero-api-label">Available bindings:</div><pre>${hint}</pre></div>`
			: '<div class="hero-placeholder">Run the mod to see output here.</div>';
	}

	async function boot() {
		const slot = document.getElementById("hero-playground-slot");
		const playground = document.getElementById("hero-playground");
		if (slot && playground) slot.appendChild(playground);

		const loadingEl = document.getElementById("hero-loading")!;
		const containerEl = document.getElementById("hero-pg-container")!;
		const editor = document.getElementById("hero-editor") as HTMLTextAreaElement;
		const runBtn = document.getElementById("hero-run-btn")!;
		const clearBtn = document.getElementById("hero-clear-btn")!;
		const simSelect = document.getElementById(
			"hero-sim-select"
		) as HTMLSelectElement;

		try {
			const xript = await initXript();

			// --- inject canvas into hero background ---
			const heroMain = document.querySelector("[data-has-hero] main");
			if (heroMain) {
				bgCanvas = document.createElement("canvas");
				bgCanvas.id = "hero-canvas";
				heroMain.prepend(bgCanvas);
			}

			loadingEl.style.display = "none";
			containerEl.style.display = "flex";

			// --- populate sim dropdown ---
			for (const sim of SIMS) {
				const opt = document.createElement("option");
				opt.value = sim.name;
				opt.textContent = sim.label;
				simSelect.appendChild(opt);
			}

			// --- canvas sizing ---
			function sizeCanvas() {
				if (!bgCanvas || !heroMain) return;
				const rect = (heroMain as HTMLElement).getBoundingClientRect();
				const newW = Math.floor(rect.width);
				const newH = Math.floor(rect.height);
				const widthChanged = newW !== canvasW;
				canvasW = newW;
				canvasH = newH;
				bgCanvas.width = canvasW;
				bgCanvas.height = canvasH;
				if (widthChanged && currentSim) {
					currentSim.state = currentSim.init(bgCanvas, canvasW, canvasH);
				}
			}

			if (heroMain) {
				const ro = new ResizeObserver(sizeCanvas);
				ro.observe(heroMain as HTMLElement);
			}
			sizeCanvas();

			// --- switch simulation ---
			function switchSim(name: string) {
				cancelAnimationFrame(animId);
				const sim = SIMS.find((s) => s.name === name);
				if (!sim || !bgCanvas) return;
				currentSim = sim;
				sim.state = sim.init(bgCanvas, canvasW, canvasH);
				editor.value = sim.defaultCode;
				clearConsole();
				startLoop();
			}

			// --- animation loop ---
			function startLoop() {
				if (!bgCanvas || !currentSim) return;
				const ctx = bgCanvas.getContext("2d")!;
				function frame() {
					if (currentSim && bgCanvas) {
						currentSim.render(ctx, canvasW, canvasH, currentSim.state);
					}
					animId = requestAnimationFrame(frame);
				}
				animId = requestAnimationFrame(frame);
			}

			simSelect.value = SIMS[0].name;
			switchSim(SIMS[0].name);

			simSelect.addEventListener("change", () => switchSim(simSelect.value));

			// --- theme observer ---
			const themeObserver = new MutationObserver(() => {
				if (currentSim?.state) {
					currentSim.state.color = getAccentColor();
					if ("needsRedraw" in currentSim.state) {
						currentSim.state.needsRedraw = true;
					}
				}
			});
			themeObserver.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ["data-theme", "data-color-scheme"],
			});

			// --- run mod ---
			function runMod() {
				const code = editor.value.trim();
				if (!code || !currentSim) return;

				addConsole("--- running mod ---", "log");

				let runtime = null;
				try {
					const bindings = currentSim.createBindings(
						currentSim.state,
						(msg: string) => addConsole(msg, "log")
					);
					runtime = xript.createRuntime(currentSim.manifest, {
						hostBindings: bindings,
						capabilities: ["modify-world"],
						console: {
							log: (...args: unknown[]) =>
								addConsole(args.join(" "), "log"),
							warn: (...args: unknown[]) =>
								addConsole(args.join(" "), "log"),
							error: (...args: unknown[]) =>
								addConsole(args.join(" "), "error"),
						},
					});

					const result = runtime.execute(code);
					if (result.value !== undefined) {
						addConsole("=> " + JSON.stringify(result.value), "log");
					}
					addConsole(`${result.duration_ms.toFixed(1)}ms`, "log");
				} catch (err: any) {
					addConsole(err.message, "error");
				} finally {
					if (runtime) runtime.dispose();
				}
			}

			runBtn.addEventListener("click", runMod);

			editor.addEventListener("keydown", (e: KeyboardEvent) => {
				if (e.key === "Enter" && e.ctrlKey) {
					e.preventDefault();
					runMod();
				}
				if (e.key === "Tab") {
					e.preventDefault();
					const start = editor.selectionStart;
					const end = editor.selectionEnd;
					editor.value =
						editor.value.substring(0, start) +
						"  " +
						editor.value.substring(end);
					editor.selectionStart = editor.selectionEnd = start + 2;
				}
			});

			clearBtn.addEventListener("click", clearConsole);
		} catch (err: any) {
			loadingEl.innerHTML = `<p style="color: #f87171;">Failed to load sandbox: ${err.message}</p>`;
		}
	}

	boot();
</script>

