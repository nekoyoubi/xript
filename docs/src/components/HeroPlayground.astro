<script>
	import { initXript } from "@xriptjs/runtime";

	function readCSSColor(varName: string): string {
		return getComputedStyle(document.documentElement)
			.getPropertyValue(varName)
			.trim();
	}

	function getAccentColor(): string {
		return readCSSColor("--sl-color-accent") || "#e02e81";
	}

	// --- Game of Life -----------------------------------------------------------

	interface LifeState {
		grid: Uint8Array;
		cols: number;
		rows: number;
		generation: number;
		speed: number;
		color: string;
		cellSize: number;
		lastTick: number;
	}

	function lifeInit(
		_canvas: HTMLCanvasElement,
		w: number,
		h: number
	): LifeState {
		const cellSize = 10;
		const cols = Math.floor(w / cellSize);
		const rows = Math.floor(h / cellSize);
		const grid = new Uint8Array(cols * rows);
		const state: LifeState = {
			grid,
			cols,
			rows,
			generation: 0,
			speed: 8,
			color: getAccentColor(),
			cellSize,
			lastTick: 0,
		};
		lifeRandomize(state);
		return state;
	}

	function lifeRandomize(state: LifeState) {
		for (let i = 0; i < state.grid.length; i++) {
			state.grid[i] = Math.random() < 0.3 ? 1 : 0;
		}
		state.generation = 0;
	}

	function lifeSetPattern(state: LifeState, pattern: string) {
		state.grid.fill(0);
		state.generation = 0;
		const cx = Math.floor(state.cols / 2);
		const cy = Math.min(Math.floor(state.rows / 2), 15);
		const set = (dx: number, dy: number) => {
			const x = cx + dx;
			const y = cy + dy;
			if (x >= 0 && x < state.cols && y >= 0 && y < state.rows)
				state.grid[y * state.cols + x] = 1;
		};
		if (pattern === "glider") {
			set(0, -1);
			set(1, 0);
			set(-1, 1);
			set(0, 1);
			set(1, 1);
		} else if (pattern === "pulsar") {
			const offsets = [
				[-2, -1],
				[-3, -1],
				[-4, -1],
				[2, -1],
				[3, -1],
				[4, -1],
				[-2, 1],
				[-3, 1],
				[-4, 1],
				[2, 1],
				[3, 1],
				[4, 1],
				[-1, -2],
				[-1, -3],
				[-1, -4],
				[1, -2],
				[1, -3],
				[1, -4],
				[-1, 2],
				[-1, 3],
				[-1, 4],
				[1, 2],
				[1, 3],
				[1, 4],
				[-6, -2],
				[-6, -3],
				[-6, -4],
				[6, -2],
				[6, -3],
				[6, -4],
				[-6, 2],
				[-6, 3],
				[-6, 4],
				[6, 2],
				[6, 3],
				[6, 4],
				[-2, -6],
				[-3, -6],
				[-4, -6],
				[2, -6],
				[3, -6],
				[4, -6],
				[-2, 6],
				[-3, 6],
				[-4, 6],
				[2, 6],
				[3, 6],
				[4, 6],
			];
			for (const [dx, dy] of offsets) set(dx, dy);
		} else {
			lifeRandomize(state);
		}
	}

	function lifeStep(state: LifeState) {
		const { cols, rows, grid } = state;
		const next = new Uint8Array(cols * rows);
		for (let y = 0; y < rows; y++) {
			for (let x = 0; x < cols; x++) {
				let neighbors = 0;
				for (let dy = -1; dy <= 1; dy++) {
					for (let dx = -1; dx <= 1; dx++) {
						if (dx === 0 && dy === 0) continue;
						const nx = (x + dx + cols) % cols;
						const ny = (y + dy + rows) % rows;
						neighbors += grid[ny * cols + nx];
					}
				}
				const idx = y * cols + x;
				if (grid[idx]) {
					next[idx] = neighbors === 2 || neighbors === 3 ? 1 : 0;
				} else {
					next[idx] = neighbors === 3 ? 1 : 0;
				}
			}
		}
		state.grid = next;
		state.generation++;
	}

	function lifeRender(
		ctx: CanvasRenderingContext2D,
		w: number,
		h: number,
		state: LifeState
	) {
		const now = performance.now();
		const interval = 1000 / state.speed;
		if (now - state.lastTick > interval) {
			lifeStep(state);
			state.lastTick = now;
		}

		ctx.clearRect(0, 0, w, h);
		const { cols, rows, grid, cellSize, color } = state;
		for (let y = 0; y < rows; y++) {
			for (let x = 0; x < cols; x++) {
				if (grid[y * cols + x]) {
					ctx.fillStyle = color;
					ctx.fillRect(x * cellSize, y * cellSize, cellSize - 1, cellSize - 1);
					ctx.fillStyle = color + "44";
					ctx.fillRect(
						x * cellSize - 1,
						y * cellSize - 1,
						cellSize + 1,
						cellSize + 1
					);
				}
			}
		}
	}

	// --- Grid Walker ------------------------------------------------------------

	interface WalkerState {
		x: number;
		y: number;
		cellSize: number;
		cols: number;
		rows: number;
		color: string;
		trailEnabled: boolean;
		trail: Set<string>;
		lastMove: number;
		moveInterval: number;
	}

	function walkerInit(
		_canvas: HTMLCanvasElement,
		w: number,
		h: number
	): WalkerState {
		const cellSize = 28;
		const cols = Math.floor(w / cellSize);
		const rows = Math.floor(h / cellSize);
		return {
			x: Math.floor(cols / 2),
			y: Math.floor(rows * 0.15),
			cellSize,
			cols,
			rows,
			color: getAccentColor(),
			trailEnabled: true,
			trail: new Set(),
			lastMove: 0,
			moveInterval: 120,
		};
	}

	function walkerMove(state: WalkerState, dir: string) {
		if (state.trailEnabled) state.trail.add(`${state.x},${state.y}`);
		switch (dir) {
			case "up":
				state.y = (state.y - 1 + state.rows) % state.rows;
				break;
			case "down":
				state.y = (state.y + 1) % state.rows;
				break;
			case "left":
				state.x = (state.x - 1 + state.cols) % state.cols;
				break;
			case "right":
				state.x = (state.x + 1) % state.cols;
				break;
		}
	}

	function walkerAutoMove(state: WalkerState) {
		const dirs = ["up", "down", "left", "right"];
		walkerMove(state, dirs[Math.floor(Math.random() * 4)]);
	}

	function walkerRender(
		ctx: CanvasRenderingContext2D,
		w: number,
		h: number,
		state: WalkerState
	) {
		const now = performance.now();
		if (now - state.lastMove > state.moveInterval) {
			walkerAutoMove(state);
			state.lastMove = now;
		}

		ctx.clearRect(0, 0, w, h);
		const { cellSize, color, trail } = state;

		for (const key of trail) {
			const [tx, ty] = key.split(",").map(Number);
			ctx.fillStyle = color + "22";
			ctx.fillRect(tx * cellSize, ty * cellSize, cellSize - 1, cellSize - 1);
		}

		ctx.fillStyle = color;
		ctx.fillRect(
			state.x * cellSize,
			state.y * cellSize,
			cellSize - 1,
			cellSize - 1
		);
		ctx.fillStyle = color + "66";
		ctx.fillRect(
			state.x * cellSize - 2,
			state.y * cellSize - 2,
			cellSize + 3,
			cellSize + 3
		);
	}

	// --- L-System ---------------------------------------------------------------

	interface LSystemState {
		axiom: string;
		rules: Record<string, string>;
		angle: number;
		iterations: number;
		color: string;
		length: number;
		needsRedraw: boolean;
	}

	function lsystemInit(
		_canvas: HTMLCanvasElement,
		_w: number,
		_h: number
	): LSystemState {
		return {
			axiom: "F",
			rules: { F: "FF+[+F-F-F]-[-F+F+F]" },
			angle: 25,
			iterations: 4,
			color: getAccentColor(),
			length: 40,
			needsRedraw: true,
		};
	}

	function lsystemGenerate(state: LSystemState): string {
		let current = state.axiom;
		for (let i = 0; i < state.iterations; i++) {
			let next = "";
			for (const ch of current) {
				next += state.rules[ch] ?? ch;
			}
			current = next;
		}
		return current;
	}

	function lsystemRender(
		ctx: CanvasRenderingContext2D,
		w: number,
		h: number,
		state: LSystemState
	) {
		if (!state.needsRedraw) return;
		state.needsRedraw = false;

		ctx.clearRect(0, 0, w, h);
		const instructions = lsystemGenerate(state);
		const rad = (state.angle * Math.PI) / 180;

		let x = w * 0.5;
		let y = 0;
		let a = Math.PI / 2;
		const stack: { x: number; y: number; a: number }[] = [];

		ctx.strokeStyle = state.color;
		ctx.lineWidth = 1;
		ctx.globalAlpha = 0.8;
		ctx.beginPath();
		ctx.moveTo(x, y);

		for (const ch of instructions) {
			switch (ch) {
				case "F":
					x += Math.cos(a) * state.length;
					y += Math.sin(a) * state.length;
					ctx.lineTo(x, y);
					break;
				case "+":
					a += rad;
					break;
				case "-":
					a -= rad;
					break;
				case "[":
					stack.push({ x, y, a });
					break;
				case "]":
					if (stack.length) {
						const s = stack.pop()!;
						x = s.x;
						y = s.y;
						a = s.a;
						ctx.moveTo(x, y);
					}
					break;
			}
		}
		ctx.stroke();
		ctx.globalAlpha = 1;
	}

	// --- Simulation registry ----------------------------------------------------

