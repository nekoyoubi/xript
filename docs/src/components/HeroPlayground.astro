		name: string;
		label: string;
		manifest: object;
		defaultCode: string;
		apiHint: string;
		state: any;
		init: (canvas: HTMLCanvasElement, w: number, h: number) => any;
		render: (ctx: CanvasRenderingContext2D, w: number, h: number, state: any) => void;
		createBindings: (state: any, log: (msg: string) => void) => Record<string, any>;
	}

