---
---

<div id="fragment-builder">
	<div class="fb-loading" id="fb-loading">
		<div class="loading-spinner"></div>
		<p>Loading fragment builder...</p>
	</div>
	<div class="fb-container" id="fb-container" style="display:none">
		<div class="fb-left">
			<div class="game-window">
				<div class="game-header" data-slot="header.status">
					<div class="game-title">Realm of Xript</div>
					<div class="header-slot" id="slot-header-status">
						<span class="header-default">LVL 12 &middot; Floor 3</span>
					</div>
				</div>
				<div class="game-body">
					<div class="game-sidebar" data-slot="sidebar.left">
						<div class="sidebar-label">sidebar.left</div>
						<div class="sidebar-slot" id="slot-sidebar-left"></div>
					</div>
					<div class="game-world">
						<div class="world-grid">
							<div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor torch"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor player"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor chest"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell floor"></div><div class="grid-cell wall"></div>
							<div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell door"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div><div class="grid-cell wall"></div>
						</div>
						<div class="overlay-region" data-slot="main.overlay">
							<div class="overlay-slot" id="slot-main-overlay"></div>
						</div>
					</div>
				</div>
				<div class="game-footer">
					<button id="fb-clear-slots-btn" class="game-btn">Clear Slots</button>
					<div class="slot-legend">
						<span class="legend-item"><span class="legend-dot sidebar-dot"></span> sidebar.left</span>
						<span class="legend-item"><span class="legend-dot header-dot"></span> header.status</span>
						<span class="legend-item"><span class="legend-dot overlay-dot"></span> main.overlay</span>
					</div>
				</div>
			</div>
		</div>
		<div class="fb-right">
			<div class="panel editor-panel">
				<div class="panel-header">
					<h3>Fragment Source</h3>
					<select id="fb-sample-select">
						<option value="">Select a sample...</option>
						<option value="health-bar">Health Bar</option>
						<option value="low-health">Low Health Warning</option>
						<option value="player-card">Player Card</option>
						<option value="event-demo">Event Demo</option>
						<option value="dangerous">Dangerous Fragment</option>
					</select>
				</div>
				<textarea id="fb-editor" spellcheck="false" autocomplete="off" rows="8"></textarea>
				<div class="editor-footer">
					<label class="slot-picker">
						<span>Slot:</span>
						<select id="fb-slot-select">
							<option value="sidebar.left">sidebar.left</option>
							<option value="header.status">header.status</option>
							<option value="main.overlay">main.overlay</option>
						</select>
					</label>
					<button id="fb-mount-btn" class="run-button">Mount</button>
				</div>
			</div>
			<div class="panel state-panel">
				<div class="panel-header">
					<h3>Bindings</h3>
					<label class="cap-checkbox">
						<input type="checkbox" id="fb-cap-toggle" checked />
						<span><code>ui-mount</code></span>
					</label>
				</div>
				<div class="state-controls" id="fb-state-controls">
					<div class="control-row">
						<label>health</label>
						<input type="range" id="fb-health" min="0" max="100" value="80" />
						<span class="control-value" id="fb-health-val">80</span>
					</div>
					<div class="control-row">
						<label>maxHealth</label>
						<input type="range" id="fb-max-health" min="50" max="200" value="100" />
						<span class="control-value" id="fb-max-health-val">100</span>
					</div>
					<div class="control-row">
						<label>playerName</label>
						<input type="text" id="fb-player-name" value="Adventurer" />
					</div>
				</div>
			</div>
			<div class="panel console-panel">
				<div class="panel-header">
					<h3>Console</h3>
					<button id="fb-clear-btn" class="clear-button">Clear</button>
				</div>
				<div class="fb-console" id="fb-console">
					<div class="output-placeholder">Mount a fragment to see output here.</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import { sanitizeHTMLDetailed } from "@xriptjs/sanitize";

	const samples = {
		"health-bar": {
			html: '<div class="health-bar">\n\t<div class="bar-label">Health</div>\n\t<div class="bar-track">\n\t\t<span data-bind="health">0</span> / <span data-bind="maxHealth">0</span>\n\t</div>\n</div>',
			bindings: [
				{ name: "health", path: "health" },
				{ name: "maxHealth", path: "maxHealth" },
			],
		},
		"low-health": {
			html: '<div class="warnings">\n\t<div data-if="health < 50" class="warning">Low health!</div>\n\t<div data-if="health < 20" class="critical">Critical — find a healer!</div>\n\t<div data-if="health >= 50" class="safe">Health is fine.</div>\n</div>',
			bindings: [
				{ name: "health", path: "health" },
			],
		},
		"player-card": {
			html: '<div class="player-card">\n\t<div class="card-name" data-bind="playerName">Player</div>\n\t<div class="card-stat">\n\t\tHP: <span data-bind="health">0</span>/<span data-bind="maxHealth">0</span>\n\t</div>\n\t<div data-if="health < 30" class="card-danger">In danger!</div>\n</div>',
			bindings: [
				{ name: "playerName", path: "playerName" },
				{ name: "health", path: "health" },
				{ name: "maxHealth", path: "maxHealth" },
			],
		},
		"event-demo": {
			html: '<div class="event-panel">\n\t<button data-action="heal" class="heal-btn">Heal +10</button>\n\t<button data-action="damage" class="dmg-btn">Damage -10</button>\n\t<div class="status">HP: <span data-bind="health">0</span></div>\n</div>',
			bindings: [
				{ name: "health", path: "health" },
			],
			events: [
				{ selector: "[data-action='heal']", on: "click", handler: "onHeal" },
				{ selector: "[data-action='damage']", on: "click", handler: "onDamage" },
			],
		},
		"dangerous": {
			html: '<div class="safe-content">\n\t<p>This is safe.</p>\n</div>\n<script>alert("XSS!")<\/script>\n<div onclick="steal()" class="trap">Click me</div>\n<iframe src="evil.com"></iframe>\n<a href="javascript:void(0)">Bad link</a>\n<p data-bind="playerName">Name goes here</p>',
			bindings: [
				{ name: "playerName", path: "playerName" },
			],
		},
	};

	const appManifest = {
		xript: "0.4",
		name: "fragment-builder",
		version: "1.0.0",
		bindings: {
			log: { description: "Log a message", params: [{ name: "msg", type: "string" }] },
		},
		capabilities: {
			"ui-mount": { description: "Mount UI fragments", risk: "low" },
		},
		slots: [
			{ id: "sidebar.left", accepts: ["text/html"], multiple: true, style: "isolated" },
			{ id: "header.status", accepts: ["text/html"], multiple: false, style: "inherit" },
			{ id: "main.overlay", accepts: ["text/html"], capability: "ui-mount", multiple: true, style: "scoped" },
		],
	};

	let state = { health: 80, maxHealth: 100, playerName: "Adventurer" };
	let mountedFragments = [];

	function addConsole(text, level = "log") {
		const el = document.getElementById("fb-console");
		const placeholder = el.querySelector(".output-placeholder");
		if (placeholder) placeholder.remove();

		const line = document.createElement("div");
		line.className = `console-line ${level}`;
		const prefix = level === "log" ? "[log] " : level === "error" ? "[err] " : "=> ";
		line.textContent = `${prefix}${text}`;
		el.appendChild(line);
		el.scrollTop = el.scrollHeight;
	}

	function resolveBindings(bindings, data) {
		const resolved = {};
		for (const b of bindings) {
			resolved[b.name] = data[b.path];
		}
		return resolved;
	}

	function applyDataBind(container, bindings) {
		const elements = container.querySelectorAll("[data-bind]");
		for (const el of elements) {
			const name = el.getAttribute("data-bind");
			if (bindings[name] !== undefined) {
				if (el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.tagName === "SELECT") {
					el.value = String(bindings[name]);
				} else {
					el.textContent = String(bindings[name]);
				}
			}
		}
	}

	function applyDataIf(container, bindings) {
		const safeId = /^[a-zA-Z_$][a-zA-Z0-9_$]*$/;
		const elements = container.querySelectorAll("[data-if]");
		for (const el of elements) {
			const expr = el.getAttribute("data-if");
			try {
				const vars = Object.entries(bindings)
					.filter(([k]) => safeId.test(k))
					.map(([k, v]) => `var ${k} = ${JSON.stringify(v)};`)
					.join(" ");
				const result = new Function(`${vars} return !!(${expr})`)();
				el.style.display = result ? "" : "none";
			} catch {
				el.style.display = "none";
			}
		}
	}

	function renderFragments() {
		for (const frag of mountedFragments) {
			const bindings = resolveBindings(frag.bindings, state);
			applyDataBind(frag.container, bindings);
			applyDataIf(frag.container, bindings);
		}
	}

	function mountFragment(html, slotId, bindings, events) {
		const slotEl = document.getElementById(`slot-${slotId.replace(/\./g, "-")}`);
		if (!slotEl) {
			addConsole(`Slot '${slotId}' not found`, "error");
			return;
		}

		const sanitizeResult = sanitizeHTMLDetailed(html);

		if (sanitizeResult.strippedElements.length > 0 || sanitizeResult.strippedAttributes.length > 0) {
			addConsole("Sanitizer stripped dangerous content:", "log");
			for (const tag of sanitizeResult.strippedElements) {
				addConsole(`  stripped <${tag}>`, "error");
			}
			for (const attr of sanitizeResult.strippedAttributes) {
				addConsole(`  stripped ${attr.attribute} on <${attr.element}>`, "error");
			}
		} else {
			addConsole("Fragment is clean — nothing stripped", "log");
		}

		const wrapper = document.createElement("div");
		wrapper.className = "fragment-wrapper";
		wrapper.innerHTML = sanitizeResult.html;
		slotEl.appendChild(wrapper);

		const resolved = resolveBindings(bindings, state);
		applyDataBind(wrapper, resolved);
		applyDataIf(wrapper, resolved);

		if (events) {
			for (const evt of events) {
				const targets = wrapper.querySelectorAll(evt.selector);
				for (const target of targets) {
					target.addEventListener(evt.on, () => {
						addConsole(`Event: ${evt.on} → ${evt.handler}()`, "result");
						if (evt.handler === "onHeal") {
							state.health = Math.min(state.health + 10, state.maxHealth);
							document.getElementById("fb-health").value = String(state.health);
							document.getElementById("fb-health-val").textContent = String(state.health);
							renderFragments();
						} else if (evt.handler === "onDamage") {
							state.health = Math.max(state.health - 10, 0);
							document.getElementById("fb-health").value = String(state.health);
							document.getElementById("fb-health-val").textContent = String(state.health);
							renderFragments();
						}
					});
				}
			}
		}

		mountedFragments.push({ container: wrapper, bindings });
		addConsole(`Mounted into ${slotId}`, "result");
	}

	async function boot() {
		try {
			const loadingEl = document.getElementById("fb-loading");
			const containerEl = document.getElementById("fb-container");
			loadingEl.style.display = "none";
			containerEl.style.display = "grid";

			const editor = document.getElementById("fb-editor");
			const sampleSelect = document.getElementById("fb-sample-select");
			const slotSelect = document.getElementById("fb-slot-select");
			const mountBtn = document.getElementById("fb-mount-btn");
			const clearBtn = document.getElementById("fb-clear-btn");
			const clearSlotsBtn = document.getElementById("fb-clear-slots-btn");
			const healthSlider = document.getElementById("fb-health");
			const maxHealthSlider = document.getElementById("fb-max-health");
			const playerNameInput = document.getElementById("fb-player-name");
			const capToggle = document.getElementById("fb-cap-toggle");

			sampleSelect.value = "health-bar";
			editor.value = samples["health-bar"].html;

			sampleSelect.addEventListener("change", () => {
				const sample = samples[sampleSelect.value];
				if (sample) editor.value = sample.html;
			});

			clearSlotsBtn.addEventListener("click", () => {
				document.getElementById("slot-sidebar-left").innerHTML = "";
				document.getElementById("slot-main-overlay").innerHTML = "";
				document.getElementById("slot-header-status").innerHTML = '<span class="header-default">LVL 12 &middot; Floor 3</span>';
				mountedFragments = [];
				addConsole("cleared all slots", "log");
			});

			mountBtn.addEventListener("click", () => {
				const html = editor.value.trim();
				if (!html) return;

				const slotId = slotSelect.value;
				const slotDef = appManifest.slots.find(s => s.id === slotId);

				if (slotDef.capability && !capToggle.checked) {
					addConsole(`CapabilityDeniedError: slot '${slotId}' requires '${slotDef.capability}'`, "error");
					return;
				}

				const sampleKey = sampleSelect.value;
				const sample = samples[sampleKey];
				const bindings = sample?.bindings || [];
				const events = sample?.events || [];

				mountFragment(html, slotId, bindings, events);
			});

			clearBtn.addEventListener("click", () => {
				const consoleEl = document.getElementById("fb-console");
				consoleEl.innerHTML = '<div class="output-placeholder">Mount a fragment to see output here.</div>';
			});

			healthSlider.addEventListener("input", () => {
				state.health = parseInt(healthSlider.value);
				document.getElementById("fb-health-val").textContent = String(state.health);
				renderFragments();
			});

			maxHealthSlider.addEventListener("input", () => {
				state.maxHealth = parseInt(maxHealthSlider.value);
				document.getElementById("fb-max-health-val").textContent = String(state.maxHealth);
				renderFragments();
			});

			playerNameInput.addEventListener("input", () => {
				state.playerName = playerNameInput.value;
				renderFragments();
			});

			addConsole("ready to mount fragments", "log");
		} catch (err) {
			const loadingEl = document.getElementById("fb-loading");
			loadingEl.innerHTML = `<p style="color: #f87171;">Failed to load: ${err.message}</p>`;
		}
	}

	boot();
</script>

<style>
	#fragment-builder {
		margin-top: 1rem;
	}

	.fb-loading {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem;
		color: var(--sl-color-gray-2);
	}

	.loading-spinner {
		width: 2rem;
		height: 2rem;
		border: 3px solid var(--sl-color-gray-5);
		border-top-color: var(--sl-color-accent);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
		margin-bottom: 1rem;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	.fb-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		min-height: 500px;
	}

	@media (max-width: 900px) {
		.fb-container {
			grid-template-columns: 1fr;
		}
	}

	/* ── Game Window ── */

	.game-window {
		background: #0a0a0f;
		border: 2px solid #2a2a3a;
		border-radius: 0.5rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 30px rgba(0, 0, 0, 0.3);
	}

	.game-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.375rem 0.75rem;
		background: linear-gradient(180deg, #1a1a2e 0%, #12121f 100%);
		border-bottom: 1px solid #2a2a3a;
		min-height: 1.75rem;
	}

	.game-title {
		font-family: var(--sl-font-mono);
		font-size: 0.75rem;
		font-weight: 700;
		color: #c8a86e;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.header-default) {
		font-family: var(--sl-font-mono);
		font-size: 0.6875rem;
		color: #6a6a8a;
	}

	:global(.header-slot) {
		font-family: var(--sl-font-mono);
		font-size: 0.6875rem;
	}

	.game-body {
		display: flex;
		flex: 1;
		min-height: 300px;
	}

	.game-sidebar {
		width: 140px;
		border-right: 1px solid #2a2a3a;
		background: linear-gradient(180deg, #111120 0%, #0d0d18 100%);
		display: flex;
		flex-direction: column;
		flex-shrink: 0;
	}

	.sidebar-label {
		font-family: var(--sl-font-mono);
		font-size: 0.5625rem;
		color: #4a4a6a;
		padding: 0.25rem 0.5rem;
		border-bottom: 1px solid #1a1a2a;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	:global(.sidebar-slot) {
		padding: 0.375rem 0.5rem;
		flex: 1;
		font-size: 0.8125rem;
	}

	.game-world {
		flex: 1;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.world-grid {
		display: grid;
		grid-template-columns: repeat(8, 1fr);
		gap: 1px;
		width: 80%;
		max-width: 280px;
		aspect-ratio: 8/7;
		opacity: 0.6;
	}

	.grid-cell {
		aspect-ratio: 1;
		border-radius: 1px;
	}

	.grid-cell.wall { background: #1a1a2e; }
	.grid-cell.floor { background: #1e1e30; }
	.grid-cell.door { background: #3a2a1a; }
	.grid-cell.player { background: #2a6a4a; box-shadow: 0 0 4px #4ade80; }
	.grid-cell.torch { background: #4a3a1a; box-shadow: 0 0 3px #fbbf24; }
	.grid-cell.chest { background: #3a3a1a; box-shadow: 0 0 3px #c8a86e; }

	.overlay-region {
		position: absolute;
		bottom: 0.5rem;
		left: 0.5rem;
		right: 0.5rem;
		min-height: 2rem;
	}

	:global(.overlay-slot) {
		font-size: 0.8125rem;
	}

	.game-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.25rem 0.5rem;
		border-top: 1px solid #2a2a3a;
		background: #0d0d18;
	}

	.game-btn {
		font-family: var(--sl-font-mono);
		font-size: 0.5625rem;
		padding: 0.125rem 0.375rem;
		background: transparent;
		color: #6a6a8a;
		border: 1px solid #2a2a3a;
		border-radius: 0.25rem;
		cursor: pointer;
		transition: all 0.15s;
	}

	.game-btn:hover {
		color: #c8a86e;
		border-color: #c8a86e;
	}

	.slot-legend {
		display: flex;
		gap: 0.75rem;
		font-family: var(--sl-font-mono);
		font-size: 0.5625rem;
		color: #4a4a6a;
	}

	.legend-item {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.legend-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}

	.sidebar-dot { background: #7dd3fc; }
	.header-dot { background: #c8a86e; }
	.overlay-dot { background: #c4b5fd; }

	/* ── Right Side Panels ── */

	.panel {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.panel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-black);
	}

	.panel-header h3 {
		margin: 0;
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-2);
	}

	.panel-header select {
		font-family: var(--sl-font-mono);
		font-size: 0.6875rem;
		padding: 0.125rem 0.375rem;
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-2);
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 0.25rem;
		cursor: pointer;
	}

	#fb-editor {
		flex: 1;
		width: 100%;
		box-sizing: border-box;
		font-family: var(--sl-font-mono);
		font-size: 0.75rem;
		padding: 0.5rem;
		background: var(--sl-color-black);
		color: var(--sl-color-white);
		border: none;
		resize: none;
		outline: none;
		line-height: 1.5;
		tab-size: 2;
