					<div class="control-row">
						<label>health</label>
						<input type="range" id="fb-health" min="0" max="100" value="80" />
						<span class="control-value" id="fb-health-val">80</span>
					</div>
					<div class="control-row">
						<label>maxHealth</label>
						<input type="range" id="fb-max-health" min="50" max="200" value="100" />
						<span class="control-value" id="fb-max-health-val">100</span>
					</div>
					<div class="control-row">
						<label>playerName</label>
						<input type="text" id="fb-player-name" value="Adventurer" />
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import { sanitizeHTMLDetailed } from "@xriptjs/sanitize";
	import { CodeJar } from "codejar";

	function highlightHTML(el) {
		const code = el.textContent || "";
		el.innerHTML = code
			.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
			.replace(/&lt;(\/?)([\w-]+)((?:\s+[^&]*)?)&gt;/g, (_, slash, tag, attrs) => {
				const hlAttrs = attrs.replace(/([\w-]+)=&quot;([^&]*?)&quot;/g,
					'<span class="hl-attr">$1</span>=<span class="hl-str">&quot;$2&quot;</span>');
				return `&lt;<span class="hl-tag">${slash}${tag}</span>${hlAttrs}&gt;`;
			});
	}

	const samples = {
		"health-bar": {
			html: '<div class="health-bar">\n\t<div class="bar-label">Health</div>\n\t<div class="bar-track">\n\t\t<span data-bind="health">0</span> / <span data-bind="maxHealth">0</span>\n\t</div>\n</div>',
			bindings: [{ name: "health", path: "health" }, { name: "maxHealth", path: "maxHealth" }],
		},
		"low-health": {
			html: '<div class="warnings">\n\t<div data-if="health < 50" class="warning">Low health!</div>\n\t<div data-if="health < 20" class="critical">Critical — find a healer!</div>\n\t<div data-if="health >= 50" class="safe">Health is fine.</div>\n</div>',
			bindings: [{ name: "health", path: "health" }],
		},
		"player-card": {
			html: '<div class="player-card">\n\t<div class="card-name" data-bind="playerName">Player</div>\n\t<div class="card-stat">\n\t\tHP: <span data-bind="health">0</span>/<span data-bind="maxHealth">0</span>\n\t</div>\n\t<div data-if="health < 30" class="card-danger">In danger!</div>\n</div>',
			bindings: [{ name: "playerName", path: "playerName" }, { name: "health", path: "health" }, { name: "maxHealth", path: "maxHealth" }],
		},
		"event-demo": {
			html: '<div class="event-panel">\n\t<button data-action="heal" class="heal-btn">Heal +10</button>\n\t<button data-action="damage" class="dmg-btn">Damage -10</button>\n\t<div class="status">HP: <span data-bind="health">0</span></div>\n</div>',
			bindings: [{ name: "health", path: "health" }],
			events: [{ selector: "[data-action='heal']", on: "click", handler: "onHeal" }, { selector: "[data-action='damage']", on: "click", handler: "onDamage" }],
		},
		"dangerous": {
			html: '<div class="safe-content">\n\t<p>This is safe.</p>\n</div>\n<script>alert("XSS!")<\/script>\n<div onclick="steal()" class="trap">Click me</div>\n<iframe src="evil.com"></iframe>\n<a href="javascript:void(0)">Bad link</a>\n<p data-bind="playerName">Name goes here</p>',
			bindings: [{ name: "playerName", path: "playerName" }],
		},
	};

	const appManifest = {
		xript: "0.4", name: "fragment-builder", version: "1.0.0",
		bindings: { log: { description: "Log a message", params: [{ name: "msg", type: "string" }] } },
		capabilities: { "ui-mount": { description: "Mount UI fragments", risk: "low" } },
		slots: [
			{ id: "sidebar.left", accepts: ["text/html"], multiple: true, style: "isolated" },
			{ id: "header.status", accepts: ["text/html"], multiple: false, style: "inherit" },
			{ id: "main.overlay", accepts: ["text/html"], capability: "ui-mount", multiple: true, style: "scoped" },
		],
	};

	let state = { health: 80, maxHealth: 100, playerName: "Adventurer" };
	let mountedFragments = [];
	let selectedSlot = "sidebar.left";
	let editorJar;

	function addConsole(text, level = "log") {
		const el = document.getElementById("fb-console");
		const placeholder = el.querySelector(".output-placeholder");
		if (placeholder) placeholder.remove();
		const line = document.createElement("div");
		line.className = `console-line ${level}`;
		const prefix = level === "log" ? "[log] " : level === "error" ? "[err] " : "=> ";
		line.textContent = `${prefix}${text}`;
		el.appendChild(line);
		el.scrollTop = el.scrollHeight;
	}

	function resolveBindings(bindings, data) {
		const resolved = {};
		for (const b of bindings) resolved[b.name] = data[b.path];
		return resolved;
	}

	function applyDataBind(container, bindings) {
		for (const el of container.querySelectorAll("[data-bind]")) {
			const name = el.getAttribute("data-bind");
			if (bindings[name] !== undefined) {
				el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.tagName === "SELECT"
					? el.value = String(bindings[name])
					: el.textContent = String(bindings[name]);
			}
		}
	}

	function applyDataIf(container, bindings) {
		const safeId = /^[a-zA-Z_$][a-zA-Z0-9_$]*$/;
		for (const el of container.querySelectorAll("[data-if]")) {
			try {
				const vars = Object.entries(bindings).filter(([k]) => safeId.test(k)).map(([k, v]) => `var ${k} = ${JSON.stringify(v)};`).join(" ");
				el.style.display = new Function(`${vars} return !!(${el.getAttribute("data-if")})`)() ? "" : "none";
			} catch { el.style.display = "none"; }
		}
	}

	function renderFragments() {
		for (const frag of mountedFragments) {
			const bindings = resolveBindings(frag.bindings, state);
			applyDataBind(frag.container, bindings);
			applyDataIf(frag.container, bindings);
		}
	}

	function unmountFragment(wrapper) {
		mountedFragments = mountedFragments.filter(f => f.container !== wrapper);
		wrapper.remove();
		addConsole("unmounted fragment", "log");
	}

	function mountFragment(html, slotId, bindings, events) {
		const slotEl = document.getElementById(`slot-${slotId.replace(/\./g, "-")}`);
		if (!slotEl) { addConsole(`Slot '${slotId}' not found`, "error"); return; }

		const sanitizeResult = sanitizeHTMLDetailed(html);
		if (sanitizeResult.strippedElements.length > 0 || sanitizeResult.strippedAttributes.length > 0) {
			addConsole("Sanitizer stripped dangerous content:", "log");
			for (const tag of sanitizeResult.strippedElements) addConsole(`  stripped <${tag}>`, "error");
			for (const attr of sanitizeResult.strippedAttributes) addConsole(`  stripped ${attr.attribute} on <${attr.element}>`, "error");
		} else {
			addConsole("Fragment is clean — nothing stripped", "log");
		}

		const wrapper = document.createElement("div");
		wrapper.className = "fragment-wrapper";

		const closeBtn = document.createElement("button");
		closeBtn.className = "fragment-close";
		closeBtn.textContent = "\u00d7";
		closeBtn.addEventListener("click", () => unmountFragment(wrapper));
		wrapper.appendChild(closeBtn);

		const content = document.createElement("div");
		content.className = "fragment-content";
		content.innerHTML = sanitizeResult.html;
		wrapper.appendChild(content);

		slotEl.appendChild(wrapper);

		const resolved = resolveBindings(bindings, state);
		applyDataBind(content, resolved);
		applyDataIf(content, resolved);

		if (events) {
			for (const evt of events) {
				for (const target of content.querySelectorAll(evt.selector)) {
					target.addEventListener(evt.on, () => {
						addConsole(`Event: ${evt.on} → ${evt.handler}()`, "result");
						if (evt.handler === "onHeal") {
							state.health = Math.min(state.health + 10, state.maxHealth);
							document.getElementById("fb-health").value = String(state.health);
							document.getElementById("fb-health-val").textContent = String(state.health);
							renderFragments();
						} else if (evt.handler === "onDamage") {
							state.health = Math.max(state.health - 10, 0);
							document.getElementById("fb-health").value = String(state.health);
							document.getElementById("fb-health-val").textContent = String(state.health);
							renderFragments();
						}
					});
				}
			}
		}

		mountedFragments.push({ container: wrapper, bindings });
		addConsole(`Mounted into ${slotId}`, "result");
	}

	function boot() {
		try {
			document.getElementById("fb-loading").style.display = "none";
			document.getElementById("fb-container").style.display = "grid";

			const editorEl = document.getElementById("fb-editor");
			editorJar = CodeJar(editorEl, highlightHTML, { tab: "\t" });

			const sampleSelect = document.getElementById("fb-sample-select");
			const capToggle = document.getElementById("fb-cap-toggle");

			sampleSelect.value = "health-bar";
			editorJar.updateCode(samples["health-bar"].html);

			sampleSelect.addEventListener("change", () => {
				const sample = samples[sampleSelect.value];
				if (sample) editorJar.updateCode(sample.html);
			});

			for (const pill of document.querySelectorAll(".slot-pill")) {
				pill.addEventListener("click", () => {
					document.querySelector(".slot-pill.active")?.classList.remove("active");
					pill.classList.add("active");
					selectedSlot = pill.dataset.slot;
				});
			}

			document.getElementById("fb-clear-slots-btn").addEventListener("click", () => {
				document.getElementById("slot-sidebar-left").innerHTML = "";
				document.getElementById("slot-main-overlay").innerHTML = "";
				document.getElementById("slot-header-status").innerHTML = '<span class="header-default">LVL 12 &middot; Floor 3</span>';
				mountedFragments = [];
				addConsole("cleared all slots", "log");
			});

			document.getElementById("fb-mount-btn").addEventListener("click", () => {
				const html = editorJar.toString().trim();
				if (!html) return;

				const slotDef = appManifest.slots.find(s => s.id === selectedSlot);
				if (slotDef.capability && !capToggle.checked) {
					addConsole(`CapabilityDeniedError: slot '${selectedSlot}' requires '${slotDef.capability}'`, "error");
					return;
				}

				const sampleKey = sampleSelect.value;
				const sample = samples[sampleKey];
				mountFragment(html, selectedSlot, sample?.bindings || [], sample?.events || []);
			});

			document.getElementById("fb-clear-btn").addEventListener("click", () => {
				document.getElementById("fb-console").innerHTML = '<div class="output-placeholder">Mount a fragment to see output here.</div>';
			});

			document.getElementById("fb-health").addEventListener("input", (e) => {
				state.health = parseInt(e.target.value);
				document.getElementById("fb-health-val").textContent = String(state.health);
				renderFragments();
			});

			document.getElementById("fb-max-health").addEventListener("input", (e) => {
				state.maxHealth = parseInt(e.target.value);
				document.getElementById("fb-max-health-val").textContent = String(state.maxHealth);
				renderFragments();
			});

			document.getElementById("fb-player-name").addEventListener("input", (e) => {
				state.playerName = e.target.value;
				renderFragments();
			});

			addConsole("ready to mount fragments", "log");
		} catch (err) {
			document.getElementById("fb-loading").innerHTML = `<p style="color: #f87171;">Failed to load: ${err.message}</p>`;
		}
	}

	boot();
</script>

<style>
	#fragment-builder { margin-top: 1rem; }

	.fb-loading {
		display: flex; flex-direction: column; align-items: center;
		justify-content: center; padding: 4rem 2rem; color: var(--sl-color-gray-2);
	}
	.loading-spinner {
		width: 2rem; height: 2rem; border: 3px solid var(--sl-color-gray-5);
		border-top-color: var(--sl-color-accent); border-radius: 50%;
		animation: spin 0.8s linear infinite; margin-bottom: 1rem;
	}
	@keyframes spin { to { transform: rotate(360deg); } }

	.fb-container {
		display: grid; grid-template-columns: 1fr 1fr;
		gap: 1rem; min-height: 500px;
	}
	@media (max-width: 900px) { .fb-container { grid-template-columns: 1fr; } }

	.fb-left { display: flex; flex-direction: column; gap: 0.5rem; }
	.fb-right { display: flex; flex-direction: column; gap: 0.5rem; }

	/* ── Game Window ── */

	.game-window {
		background: #0a0a0f; border: 2px solid #2a2a3a; border-radius: 0.5rem;
		overflow: hidden; display: flex; flex-direction: column;
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 30px rgba(0, 0, 0, 0.3);
	}
	.game-header {
		display: flex; align-items: center; justify-content: space-between;
		padding: 0.375rem 0.75rem; background: linear-gradient(180deg, #1a1a2e 0%, #12121f 100%);
		border-bottom: 1px solid #2a2a3a; min-height: 1.75rem;
	}
	.game-title {
		font-family: var(--sl-font-mono); font-size: 0.75rem; font-weight: 700;
		color: #c8a86e; letter-spacing: 0.1em; text-transform: uppercase;
	}
	:global(.header-default) { font-family: var(--sl-font-mono); font-size: 0.6875rem; color: #6a6a8a; }
	:global(.header-slot) { font-family: var(--sl-font-mono); font-size: 0.6875rem; }

	.game-body { display: flex; flex: 1; min-height: 280px; }
	.game-sidebar {
		width: 140px; border-right: 1px solid #2a2a3a; flex-shrink: 0;
		background: linear-gradient(180deg, #111120 0%, #0d0d18 100%);
		display: flex; flex-direction: column;
	}
	.sidebar-label {
		font-family: var(--sl-font-mono); font-size: 0.5625rem; color: #4a4a6a;
		padding: 0.25rem 0.5rem; border-bottom: 1px solid #1a1a2a;
		text-transform: uppercase; letter-spacing: 0.05em;
	}
	:global(.sidebar-slot) { padding: 0.375rem 0.5rem; flex: 1; font-size: 0.8125rem; }

	.game-world {
		flex: 1; position: relative; display: flex;
		align-items: center; justify-content: center; overflow: hidden;
	}
	.dungeon-map {
		font-family: var(--sl-font-mono); font-size: 0.875rem; line-height: 1.3;
		letter-spacing: 0.15em; margin: 0; padding: 0; color: #3a3a5a; user-select: none;
	}
	:global(.t-wall) { color: #4a4a6a; }
	:global(.t-floor) { color: #2a2a3e; }
	:global(.t-player) { color: #4ade80; text-shadow: 0 0 6px #4ade80; font-weight: 700; }
	:global(.t-torch) { color: #fbbf24; text-shadow: 0 0 5px #b4841a; }
	:global(.t-chest) { color: #c8a86e; text-shadow: 0 0 4px #c8a86e; }
	:global(.t-door) { color: #8b6914; }

	.overlay-region { position: absolute; bottom: 0.5rem; left: 0.5rem; right: 0.5rem; min-height: 2rem; }
	:global(.overlay-slot) { font-size: 0.8125rem; }

	.game-footer {
		display: flex; align-items: center; justify-content: space-between;
		padding: 0.25rem 0.5rem; border-top: 1px solid #2a2a3a; background: #0d0d18;
	}
	.game-btn {
		font-family: var(--sl-font-mono); font-size: 0.5625rem; padding: 0.125rem 0.375rem;
		background: transparent; color: #6a6a8a; border: 1px solid #2a2a3a;
		border-radius: 0.25rem; cursor: pointer; transition: all 0.15s;
	}
	.game-btn:hover { color: #c8a86e; border-color: #c8a86e; }

	.slot-legend { display: flex; gap: 0.75rem; font-family: var(--sl-font-mono); font-size: 0.5625rem; color: #4a4a6a; }
	.legend-item { display: flex; align-items: center; gap: 0.25rem; }
	.legend-dot { width: 6px; height: 6px; border-radius: 50%; }
	.sidebar-dot { background: #7dd3fc; }
	.header-dot { background: #c8a86e; }
	.overlay-dot { background: #c4b5fd; }

	/* ── Fragment wrappers with [x] ── */

	:global(.fragment-wrapper) {
		position: relative; padding: 0.25rem 0; padding-right: 1.25rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
