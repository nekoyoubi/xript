---
interface Props {
	title?: string;
}
const { title } = Astro.props;
---

<div class="terminal">
	<div class="terminal-bar">
		<div class="terminal-dots">
			<span class="dot dot-red"></span>
			<span class="dot dot-yellow"></span>
			<span class="dot dot-green"></span>
		</div>
		{title && <span class="terminal-title">{title}</span>}
	</div>
	<div class="terminal-body">
		<slot />
	</div>
</div>

<style>
	.terminal {
		border-radius: 0.5rem;
		border: 1px solid var(--sl-color-gray-5);
		overflow: hidden;
		margin: 1.5rem 0;
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.625rem 0.875rem;
		background: var(--sl-color-black);
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.terminal-dots {
		display: flex;
		gap: 0.375rem;
	}

	.dot {
		width: 0.625rem;
		height: 0.625rem;
		border-radius: 50%;
	}

	.dot-red { background: #ff5f57; }
	.dot-yellow { background: #febc2e; }
	.dot-green { background: #28c840; }

	.terminal-title {
		font-family: var(--sl-font-mono);
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
		user-select: none;
	}

	.terminal-body {
		background: var(--sl-color-gray-6);
		padding: 1rem 1.25rem;
		font-family: var(--sl-font-mono);
		font-size: 0.8125rem;
		line-height: 1.6;
		color: var(--sl-color-gray-1);
		overflow-x: auto;
	}

	.terminal-body :global(.term-cyan) { color: #5fc9e7; }
	.terminal-body :global(.term-green) { color: #28c840; }
	.terminal-body :global(.term-red) { color: #ff5f57; }
	.terminal-body :global(.term-yellow) { color: #febc2e; }
	.terminal-body :global(.term-accent) { color: var(--sl-color-accent); }
	.terminal-body :global(.term-muted) { color: var(--sl-color-gray-4); }
	.terminal-body :global(.term-bold) { font-weight: 700; }
	.terminal-body :global(.term-dim) { opacity: 0.5; }

	.terminal-body :global(.term-card) {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.375rem;
		padding: 0.5rem 0.75rem;
		margin: 0.375rem 0;
	}

	.terminal-body :global(.term-card-active) {
		border-color: #5fc9e7;
	}

	.terminal-body :global(.term-card-title) {
		font-weight: 700;
	}

	.terminal-body :global(.term-card-desc) {
		color: var(--sl-color-gray-3);
	}

	.terminal-body :global(.term-report) {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.375rem;
		padding: 0.75rem 1rem;
		margin: 0.75rem 0;
	}

	.terminal-body :global(.term-report-green) {
		border-color: #28c840;
	}

	.terminal-body :global(.term-report-yellow) {
		border-color: #febc2e;
	}

	.terminal-body :global(.term-prompt) {
		color: #5fc9e7;
	}

	.terminal-body :global(.term-help) {
		color: var(--sl-color-gray-4);
		text-align: center;
		margin-top: 0.75rem;
		font-size: 0.75rem;
	}
</style>
