---
---

<xript-theme-select>
	<button class="mode-toggle" aria-label="Toggle light/dark mode">
		<svg class="icon-sun" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
			<path d="M12 18a6 6 0 1 1 0-12 6 6 0 0 1 0 12zm0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM11 1h2v3h-2V1zm0 19h2v3h-2v-3zM3.515 4.929l1.414-1.414L7.05 5.636 5.636 7.05 3.515 4.93zM16.95 18.364l1.414-1.414 2.121 2.121-1.414 1.414-2.121-2.121zm2.121-14.85l1.414 1.415-2.121 2.121-1.414-1.414 2.121-2.121zM5.636 16.95l1.414 1.414-2.121 2.121-1.414-1.414 2.121-2.121zM23 11v2h-3v-2h3zM4 11v2H1v-2h3z" />
		</svg>
		<svg class="icon-moon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
			<path d="M10 7a7 7 0 0 0 12 4.9v.1c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2h.1A6.979 6.979 0 0 0 10 7zm-6 5a8 8 0 0 0 15.062 3.762A9 9 0 0 1 8.238 4.938 7.999 7.999 0 0 0 4 12z" />
		</svg>
	</button>
	<div class="scheme-picker">
		<button class="scheme-toggle" aria-label="Color scheme" aria-expanded="false" aria-haspopup="true">
			<svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
				<path d="M12 2c5.522 0 10 3.978 10 8.889a5.558 5.558 0 0 1-5.556 5.555h-1.966c-.922 0-1.667.745-1.667 1.667 0 .422.167.811.422 1.1.267.3.434.689.434 1.122C13.667 21.256 12.922 22 12 22 6.478 22 2 17.522 2 12S6.478 2 12 2zm-4.5 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm3-4a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm5 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm3 4a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z" />
			</svg>
		</button>
		<div class="scheme-menu" role="listbox" aria-label="Color scheme" hidden>
			<button role="option" data-scheme="xript">
				<span class="swatch" style="background: #ee8695"></span>
				<span>xript</span>
			</button>
			<button role="option" data-scheme="chasm">
				<span class="swatch" style="background: #5fc9e7"></span>
				<span>Chasm</span>
			</button>
			<button role="option" data-scheme="inkpink">
				<span class="swatch" style="background: #fe6c90"></span>
				<span>INKPINK</span>
			</button>
			<button role="option" data-scheme="fairydust">
				<span class="swatch" style="background: #2ba9b4"></span>
				<span>Fairydust 8</span>
			</button>
		</div>
	</div>
</xript-theme-select>

<script>
	class XriptThemeSelect extends HTMLElement {
		connectedCallback() {
			const modeBtn = this.querySelector(".mode-toggle");
			const schemeBtn = this.querySelector(".scheme-toggle");
			const schemeMenu = this.querySelector(".scheme-menu");

			modeBtn?.addEventListener("click", () => {
				const html = document.documentElement;
				const next =
					html.getAttribute("data-theme") === "dark" ? "light" : "dark";
				html.setAttribute("data-theme", next);
				localStorage.setItem("starlight-theme", next);
				this.syncIcons(next);
			});

			schemeBtn?.addEventListener("click", (e) => {
				e.stopPropagation();
				const open = !schemeMenu?.hasAttribute("hidden");
				if (open) {
					schemeMenu?.setAttribute("hidden", "");
					schemeBtn.setAttribute("aria-expanded", "false");
				} else {
					schemeMenu?.removeAttribute("hidden");
					schemeBtn.setAttribute("aria-expanded", "true");
				}
			});

			schemeMenu?.addEventListener("click", (e) => {
				const option = /** @type {HTMLElement} */ (e.target)?.closest(
					"[data-scheme]",
				);
				if (!option) return;
				const scheme = /** @type {HTMLElement} */ (option).dataset.scheme;
				if (scheme === "xript") {
					document.documentElement.removeAttribute("data-color-scheme");
					localStorage.removeItem("starlight-color-scheme");
				} else {
					document.documentElement.setAttribute("data-color-scheme", scheme);
					localStorage.setItem("starlight-color-scheme", scheme);
				}
				schemeMenu.setAttribute("hidden", "");
				schemeBtn?.setAttribute("aria-expanded", "false");
				this.syncScheme();
			});

			document.addEventListener("click", (e) => {
				if (!this.contains(/** @type {Node} */ (e.target))) {
					schemeMenu?.setAttribute("hidden", "");
					schemeBtn?.setAttribute("aria-expanded", "false");
				}
			});

			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") {
					schemeMenu?.setAttribute("hidden", "");
					schemeBtn?.setAttribute("aria-expanded", "false");
				}
			});

			this.syncIcons(
				document.documentElement.getAttribute("data-theme") || "dark",
			);
			this.syncScheme();
		}

		syncIcons(theme) {
			const sun = this.querySelector(".icon-sun");
			const moon = this.querySelector(".icon-moon");
			if (sun) sun.style.display = theme === "dark" ? "block" : "none";
			if (moon) moon.style.display = theme === "light" ? "block" : "none";
		}

		syncScheme() {
			const current =
				document.documentElement.getAttribute("data-color-scheme") || "xript";
			this.querySelectorAll("[data-scheme]").forEach((btn) => {
				btn.setAttribute(
					"aria-selected",
					btn.dataset.scheme === current ? "true" : "false",
				);
			});
		}
	}

	customElements.define("xript-theme-select", XriptThemeSelect);
</script>

<style>
	xript-theme-select {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.mode-toggle,
	.scheme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0.25rem;
		border: none;
		background: transparent;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		border-radius: 0.375rem;
	}

	.mode-toggle:hover,
	.scheme-toggle:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-5);
	}

	.scheme-picker {
		position: relative;
	}

	.scheme-menu {
		position: absolute;
		right: 0;
		top: 100%;
		margin-top: 0.5rem;
		padding: 0.5rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 0.5rem;
		min-width: 10rem;
		z-index: 100;
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.scheme-menu[hidden] {
		display: none;
	}

	.scheme-menu button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		border: none;
		background: transparent;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-family: var(--sl-font);
		white-space: nowrap;
		width: 100%;
		text-align: left;
	}

	.scheme-menu button:hover {
		background: var(--sl-color-gray-5);
		color: var(--sl-color-white);
	}

	.scheme-menu button[aria-selected="true"] {
		color: var(--sl-color-accent);
	}

	.swatch {
		display: inline-block;
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		flex-shrink: 0;
	}
</style>
