---
---

<div id="fwb">
	<div class="fwb-loading" id="fwb-loading">
		<div class="loading-spinner"></div>
		<p>Loading Fragment Workbench...</p>
	</div>
	<div class="fwb-main" id="fwb-main" style="display:none">
		<nav class="fwb-tabs" id="fwb-tabs">
			<button class="tab active" data-tab="manifest"><span class="tab-num">1</span> Manifest</button>
			<button class="tab" data-tab="author"><span class="tab-num">2</span> Author</button>
			<button class="tab" data-tab="preview"><span class="tab-num">3</span> Preview</button>
			<button class="tab" data-tab="export"><span class="tab-num">4</span> Export</button>
		</nav>

		<!-- TAB 1: MANIFEST -->
		<div class="tab-content active" id="tab-manifest">
			<div class="guide" id="guide-manifest">
				<button class="guide-toggle" data-guide="manifest">
					<span class="guide-arrow">&#9656;</span>
					<span class="guide-summary">Load the app manifest your mod will target</span>
				</button>
				<div class="guide-body" style="display:none">
					<p>Every xript mod targets a specific app manifest. The manifest declares what slots are available, what data your fragment can bind to, and what capabilities it needs.</p>
					<p><strong>Quick start:</strong> Pick an example manifest below. <strong>Your own app:</strong> Select "Custom" and paste your app's <code>manifest.json</code>, or generate one with <code>xript init --yes</code>.</p>
				</div>
			</div>
			<div class="tab-panels">
				<div class="panel manifest-panel">
					<div class="panel-header">
						<h3>App Manifest</h3>
						<select id="fwb-manifest-select">
							<option value="dashboard">Dashboard App</option>
							<option value="game">Game HUD</option>
							<option value="custom">Custom...</option>
						</select>
					</div>
					<textarea id="fwb-manifest-editor" spellcheck="false" autocomplete="off"></textarea>
					<div class="manifest-status" id="fwb-manifest-status"></div>
				</div>
				<div class="panel slot-panel">
					<div class="panel-header"><h3>Slot Contract</h3></div>
					<div class="slot-contract" id="fwb-slot-contract">
						<div class="placeholder">Click a slot in the preview to inspect its contract, or load a manifest to get started.</div>
					</div>
				</div>
			</div>
		</div>

		<!-- TAB 2: AUTHOR -->
		<div class="tab-content" id="tab-author">
			<div class="guide" id="guide-author">
				<button class="guide-toggle" data-guide="author">
					<span class="guide-arrow">&#9656;</span>
					<span class="guide-summary">Write your fragment HTML (or JSML) and bind it to slot data</span>
				</button>
				<div class="guide-body" style="display:none">
					<p>Use <code>data-bind="key"</code> to display state values and <code>data-if="expr"</code> to conditionally show elements. The diagnostics bar flags unresolved bindings and anything the sanitizer will strip.</p>
					<p><strong>Tip:</strong> Check the Slot Contract (Manifest tab) to see which bindings are available. Select a sample to start from a working example.</p>
				</div>
			</div>
			<div class="tab-panels author-layout">
				<div class="panel editor-panel">
					<div class="panel-header">
						<h3>Fragment Source</h3>
						<div class="panel-actions">
							<select id="fwb-format-toggle">
								<option value="html">HTML</option>
								<option value="jsml">JSML</option>
							</select>
							<select id="fwb-sample-select">
								<option value="">Sample...</option>
							</select>
						</div>
					</div>
					<textarea id="fwb-editor" spellcheck="false" autocomplete="off"></textarea>
					<div class="editor-diagnostics" id="fwb-diagnostics"></div>
					<div class="editor-footer">
						<label class="slot-picker">
							<span>Slot:</span>
							<select id="fwb-slot-select"></select>
						</label>
						<button id="fwb-mount-btn" class="run-button">Mount</button>
					</div>
				</div>
				<div class="author-side">
					<div class="panel state-panel">
						<div class="panel-header"><h3>State Simulation</h3></div>
						<div class="state-controls" id="fwb-state-controls">
							<div class="placeholder">Load a manifest to simulate state.</div>
						</div>
					</div>
					<div class="panel console-panel">
						<div class="panel-header">
							<h3>Console</h3>
							<button id="fwb-clear-btn" class="clear-button">Clear</button>
						</div>
						<div class="fwb-console" id="fwb-console">
							<div class="placeholder">Mount a fragment to see output here.</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- TAB 3: PREVIEW -->
		<div class="tab-content" id="tab-preview">
			<div class="guide" id="guide-preview">
				<button class="guide-toggle" data-guide="preview">
					<span class="guide-arrow">&#9656;</span>
					<span class="guide-summary">See your fragments mounted in the host's slot layout</span>
				</button>
				<div class="guide-body" style="display:none">
					<p>This simulates how your fragment will appear inside the host application. Drag the state sliders (Author tab) to test how your fragment responds to changing data. Click a slot to inspect its contract.</p>
				</div>
			</div>
			<div class="tab-panels preview-layout">
				<div class="panel host-panel">
					<div class="panel-header">
						<h3>Host Preview</h3>
						<button id="fwb-clear-slots-btn" class="clear-button">Clear Slots</button>
					</div>
					<div class="host-slots" id="fwb-host-slots">
						<div class="placeholder">Load a manifest to see the host's slot layout.</div>
					</div>
				</div>
				<div class="panel slot-panel-preview">
					<div class="panel-header"><h3>Slot Contract</h3></div>
					<div class="slot-contract" id="fwb-slot-contract-preview">
						<div class="placeholder">Click a slot to inspect it.</div>
					</div>
				</div>
			</div>
		</div>

		<!-- TAB 4: EXPORT -->
		<div class="tab-content" id="tab-export">
			<div class="guide" id="guide-export">
				<button class="guide-toggle" data-guide="export">
					<span class="guide-arrow">&#9656;</span>
					<span class="guide-summary">Download your mod manifest with fragment included</span>
				</button>
				<div class="guide-body" style="display:none">
					<p>This generates a valid <code>mod-manifest.json</code> containing your fragment, targeting the slot you selected. The manifest includes any capabilities the slot requires.</p>
					<p><strong>Next steps:</strong> Place the downloaded file alongside your mod's entry script. Run <code>xript validate --cross app-manifest.json mod-manifest.json</code> to verify compatibility.</p>
				</div>
			</div>
			<div class="tab-panels">
				<div class="panel export-panel">
					<div class="panel-header">
						<h3>Mod Manifest Preview</h3>
						<button id="fwb-export-btn" class="run-button">Download</button>
					</div>
					<pre class="export-preview" id="fwb-export-preview"><span class="placeholder">Author a fragment and select a slot to see your mod manifest here.</span></pre>
				</div>
				<div class="panel export-info">
					<div class="panel-header"><h3>What's Next</h3></div>
					<div class="export-steps">
						<div class="export-step">
							<span class="step-num">1</span>
							<div>
								<strong>Download</strong> your mod manifest using the button above
							</div>
						</div>
						<div class="export-step">
							<span class="step-num">2</span>
							<div>
								<strong>Create your mod project</strong> with <code>xript init --mod</code> and replace the generated manifest with yours
							</div>
						</div>
						<div class="export-step">
							<span class="step-num">3</span>
							<div>
								<strong>Validate</strong> against the host app: <code>xript validate --cross app.json your-mod.json</code>
							</div>
						</div>
						<div class="export-step">
							<span class="step-num">4</span>
							<div>
								<strong>Add behavior</strong> with a mod entry script using the sandbox fragment API for dynamic updates
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import { sanitizeHTMLDetailed, jsmlToHtml } from "@xriptjs/sanitize";

	function validateManifest(manifest) {
		const errors = [];
		if (!manifest || typeof manifest !== "object") {
			errors.push({ message: "manifest must be an object" });
			return { valid: false, errors };
		}
		if (!manifest.xript) errors.push({ message: 'missing "xript" field' });
		if (!manifest.name) errors.push({ message: 'missing "name" field' });
		if (manifest.slots && !Array.isArray(manifest.slots)) {
			errors.push({ message: '"slots" must be an array' });
		}
		return { valid: errors.length === 0, errors };
	}

	const exampleManifests = {
		dashboard: {
			xript: "0.4",
			name: "dashboard-app",
			title: "Dashboard Application",
			version: "1.0.0",
			bindings: {
				player: {
					description: "Player info namespace",
					members: {
						getName: { description: "Get player name", returns: "string" },
						getHealth: { description: "Get player health", returns: "number" },
						getMaxHealth: { description: "Get max health", returns: "number" },
						getLevel: { description: "Get player level", returns: "number" },
					},
				},
				log: { description: "Log a message", params: [{ name: "msg", type: "string" }] },
			},
			capabilities: {
				"ui-mount": { description: "Mount UI fragments into host slots", risk: "low" },
				"read-state": { description: "Read application state", risk: "low" },
			},
			types: {
				Player: {
					description: "Player data",
					fields: {
						name: { type: "string", description: "Display name" },
						health: { type: "number", description: "Current HP" },
						maxHealth: { type: "number", description: "Maximum HP" },
						level: { type: "number", description: "Character level" },
					},
				},
			},
			slots: [
				{ id: "sidebar.left", accepts: ["text/html", "application/jsml+json"], multiple: true, style: "isolated" },
				{ id: "header.status", accepts: ["text/html"], multiple: false, style: "inherit" },
				{ id: "main.overlay", accepts: ["text/html", "application/jsml+json"], capability: "ui-mount", multiple: true, style: "scoped" },
			],
		},
		game: {
			xript: "0.4",
			name: "game-hud",
			title: "Game HUD",
			version: "2.0.0",
			bindings: {
				world: {
					description: "World state",
					members: {
						getTime: { description: "Get game time", returns: "string" },
						getWeather: { description: "Get weather condition", returns: "string" },
						getBiome: { description: "Get current biome", returns: "string" },
					},
				},
				combat: {
					description: "Combat state",
					members: {
						getEnemyCount: { description: "Get nearby enemies", returns: "number" },
						isInCombat: { description: "Check if in combat", returns: "boolean" },
					},
				},
			},
			capabilities: {
				"ui-mount": { description: "Mount UI fragments", risk: "low" },
				"combat-info": { description: "Access combat state", risk: "medium" },
			},
			slots: [
				{ id: "hud.top", accepts: ["text/html"], multiple: true, style: "inherit" },
				{ id: "hud.minimap", accepts: ["text/html"], multiple: false, style: "isolated" },
				{ id: "hud.combat", accepts: ["text/html"], capability: "combat-info", multiple: true, style: "scoped" },
			],
		},
	};

	const sampleFragments = {
		dashboard: [
			{
				name: "Health Bar",
				html: '<div class="health-bar">\n\t<div class="bar-label">Health</div>\n\t<div class="bar-track">\n\t\t<span data-bind="health">0</span> / <span data-bind="maxHealth">0</span>\n\t</div>\n</div>',
				jsml: '["div", {"class": "health-bar"},\n\t["div", {"class": "bar-label"}, "Health"],\n\t["div", {"class": "bar-track"},\n\t\t["span", {"data-bind": "health"}, "0"],\n\t\t" / ",\n\t\t["span", {"data-bind": "maxHealth"}, "0"]\n\t]\n]',
			},
			{
				name: "Player Card",
				html: '<div class="player-card">\n\t<div class="card-name" data-bind="name">Player</div>\n\t<div class="card-stat">HP: <span data-bind="health">0</span>/<span data-bind="maxHealth">0</span></div>\n\t<div class="card-stat">Level: <span data-bind="level">1</span></div>\n\t<div data-if="health < 30" class="card-danger">In danger!</div>\n</div>',
			},
			{
				name: "Low Health Warning",
				html: '<div class="warnings">\n\t<div data-if="health < 50" class="warning">Low health!</div>\n\t<div data-if="health < 20" class="critical">Critical!</div>\n\t<div data-if="health >= 50" class="safe">Health OK</div>\n</div>',
			},
			{
				name: "XSS Test",
				html: '<div class="safe-content"><p>This is safe.</p></div>\n<script>alert("XSS!")<\/script>\n<div onclick="steal()">Click me</div>\n<iframe src="evil.com"></iframe>',
			},
		],
		game: [
			{
				name: "World Info",
				html: '<div class="world-info">\n\t<div>Time: <span data-bind="time">--:--</span></div>\n\t<div>Weather: <span data-bind="weather">clear</span></div>\n\t<div>Biome: <span data-bind="biome">plains</span></div>\n</div>',
			},
			{
				name: "Combat HUD",
				html: '<div class="combat-hud">\n\t<div data-if="inCombat" class="combat-active">IN COMBAT</div>\n\t<div data-if="!inCombat" class="combat-idle">Safe</div>\n\t<div>Enemies: <span data-bind="enemyCount">0</span></div>\n</div>',
			},
		],
	};

	let currentManifest = null;
	let currentManifestKey = "dashboard";
	let state = {};
	let mountedFragments = [];
	let guideStates = {};

	function addConsole(text, level = "log") {
		const el = document.getElementById("fwb-console");
		const placeholder = el.querySelector(".placeholder");
		if (placeholder) placeholder.remove();
		const line = document.createElement("div");
		line.className = `console-line ${level}`;
		const prefix = level === "log" ? "[log] " : level === "error" ? "[err] " : "=> ";
		line.textContent = `${prefix}${text}`;
		el.appendChild(line);
		el.scrollTop = el.scrollHeight;
	}

	function buildStateFromManifest(manifest) {
		const s = {};
		if (manifest.types) {
			for (const [, typeDef] of Object.entries(manifest.types)) {
				if (!typeDef.fields) continue;
				for (const [fieldName, field] of Object.entries(typeDef.fields)) {
					if (field.type === "number") s[fieldName] = 50;
					else if (field.type === "string") s[fieldName] = fieldName;
					else if (field.type === "boolean") s[fieldName] = false;
					else s[fieldName] = null;
				}
			}
		}
		if (manifest.bindings) {
			for (const [, binding] of Object.entries(manifest.bindings)) {
				if (!binding.members) continue;
				for (const [memberName, member] of Object.entries(binding.members)) {
					const match = memberName.match(/^(?:get|is)(.+)$/);
					const key = match ? match[1].charAt(0).toLowerCase() + match[1].slice(1) : memberName;
					if (key in s) continue;
					if (member.returns === "number") s[key] = 50;
					else if (member.returns === "string") s[key] = key;
					else if (member.returns === "boolean") s[key] = false;
				}
			}
		}
		return s;
	}

	function renderStateControls() {
		const container = document.getElementById("fwb-state-controls");
		container.innerHTML = "";
		if (Object.keys(state).length === 0) {
			container.innerHTML = '<div class="placeholder">No state to simulate.</div>';
			return;
		}
		for (const [key, value] of Object.entries(state)) {
			const row = document.createElement("div");
			row.className = "control-row";
			const label = document.createElement("label");
			label.textContent = key;
			row.appendChild(label);

			if (typeof value === "number") {
				const input = document.createElement("input");
				input.type = "range";
				input.min = "0";
				input.max = "100";
				input.value = String(value);
				const valSpan = document.createElement("span");
				valSpan.className = "control-value";
				valSpan.textContent = String(value);
				input.addEventListener("input", () => {
					state[key] = parseInt(input.value);
					valSpan.textContent = String(state[key]);
					renderFragments();
				});
				row.appendChild(input);
				row.appendChild(valSpan);
			} else if (typeof value === "boolean") {
				const input = document.createElement("input");
				input.type = "checkbox";
				input.checked = value;
				input.addEventListener("change", () => {
					state[key] = input.checked;
					renderFragments();
				});
				row.appendChild(input);
			} else {
				const input = document.createElement("input");
				input.type = "text";
				input.value = String(value ?? "");
				input.addEventListener("input", () => {
					state[key] = input.value;
					renderFragments();
				});
				row.appendChild(input);
			}
			container.appendChild(row);
		}
	}

	function renderSlotRegions() {
		const container = document.getElementById("fwb-host-slots");
		const slotSelect = document.getElementById("fwb-slot-select");
		container.innerHTML = "";
		slotSelect.innerHTML = "";
		if (!currentManifest?.slots) return;

		for (const slot of currentManifest.slots) {
			const region = document.createElement("div");
			region.className = "slot-region";

			const label = document.createElement("div");
			label.className = "slot-label";
			const meta = [slot.multiple ? "multiple" : "single", slot.style || "inherit"];
			if (slot.capability) meta.push(`<code>${slot.capability}</code>`);
			label.innerHTML = `${slot.id} <span class="slot-meta">${meta.join(" \u00b7 ")}</span>`;
			region.appendChild(label);

			const content = document.createElement("div");
			content.className = "slot-content";
			content.id = `fwb-slot-${slot.id.replace(/\./g, "-")}`;
			region.appendChild(content);
			container.appendChild(region);

			const option = document.createElement("option");
			option.value = slot.id;
			option.textContent = slot.id;
			slotSelect.appendChild(option);

			region.addEventListener("click", () => {
				renderSlotContract(slot, "fwb-slot-contract");
				renderSlotContract(slot, "fwb-slot-contract-preview");
			});
		}
	}

	function renderSlotContract(slot, targetId) {
		const panel = document.getElementById(targetId);
		if (!panel) return;
		const capHtml = slot.capability
			? `<div class="contract-row"><span class="contract-label">Capability:</span> <code>${slot.capability}</code></div>`
			: "";

		const keys = Object.keys(state);
		const bindingsList = keys.length > 0
			? `<div class="contract-row"><span class="contract-label">Available bindings:</span></div>
			   <div class="binding-list">${keys.map(k => `<span class="binding-tag"><code>${k}</code> <span class="binding-type">${typeof state[k]}</span></span>`).join("")}</div>`
			: "";

		panel.innerHTML = `
			<div class="contract-header">${slot.id}</div>
			<div class="contract-row"><span class="contract-label">Accepts:</span> ${slot.accepts.join(", ")}</div>
			<div class="contract-row"><span class="contract-label">Multiple:</span> ${slot.multiple ? "yes" : "no"}</div>
			<div class="contract-row"><span class="contract-label">Style:</span> ${slot.style || "inherit"}</div>
			${capHtml}${bindingsList}`;
	}

	function renderSamples() {
		const select = document.getElementById("fwb-sample-select");
		select.innerHTML = '<option value="">Sample...</option>';
		for (const [i, frag] of (sampleFragments[currentManifestKey] || []).entries()) {
			const opt = document.createElement("option");
			opt.value = String(i);
			opt.textContent = frag.name;
			select.appendChild(opt);
		}
	}

	function applyDataBind(container, data) {
		for (const el of container.querySelectorAll("[data-bind]")) {
			const name = el.getAttribute("data-bind");
			if (data[name] !== undefined) {
				el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.tagName === "SELECT"
					? el.value = String(data[name])
					: el.textContent = String(data[name]);
			}
		}
	}

	function applyDataIf(container, data) {
		const safeId = /^[a-zA-Z_$][a-zA-Z0-9_$]*$/;
		for (const el of container.querySelectorAll("[data-if]")) {
			try {
				const vars = Object.entries(data).filter(([k]) => safeId.test(k)).map(([k, v]) => `var ${k} = ${JSON.stringify(v)};`).join(" ");
				el.style.display = new Function(`${vars} return !!(${el.getAttribute("data-if")})`)() ? "" : "none";
			} catch { el.style.display = "none"; }
		}
	}

	function renderFragments() {
		for (const frag of mountedFragments) {
			applyDataBind(frag.container, state);
			applyDataIf(frag.container, state);
		}
	}

	function runDiagnostics(html) {
		const diagEl = document.getElementById("fwb-diagnostics");
		const issues = [];
		const stateKeys = new Set(Object.keys(state));

		for (const [, ref] of html.matchAll(/data-bind="([^"]+)"/g)) {
			if (!stateKeys.has(ref)) issues.push(`<span class="diag-warn">data-bind="${ref}" — not in state</span>`);
		}
		for (const [, expr] of html.matchAll(/data-if="([^"]+)"/g)) {
			for (const token of (expr.match(/[a-zA-Z_$][a-zA-Z0-9_$]*/g) || [])) {
				if (!stateKeys.has(token) && !["true", "false", "null", "undefined"].includes(token)) {
					issues.push(`<span class="diag-warn">data-if references "${token}" — not in state</span>`);
					break;
				}
			}
		}
		const sanitized = sanitizeHTMLDetailed(html);
		for (const tag of sanitized.strippedElements) issues.push(`<span class="diag-strip">&lt;${tag}&gt; will be stripped</span>`);
		for (const attr of sanitized.strippedAttributes) issues.push(`<span class="diag-strip">${attr.attribute} on &lt;${attr.element}&gt; will be stripped</span>`);
		diagEl.innerHTML = issues.join(" \u00b7 ");
	}

	function mountFragment(html, slotId) {
		const slot = currentManifest?.slots?.find(s => s.id === slotId);
		if (!slot) { addConsole(`Slot '${slotId}' not found`, "error"); return; }
		if (slot.capability) addConsole(`Slot requires capability: ${slot.capability}`, "log");

		const sanitized = sanitizeHTMLDetailed(html);
		if (sanitized.strippedElements.length > 0 || sanitized.strippedAttributes.length > 0) {
			addConsole("Sanitizer stripped dangerous content:", "log");
			for (const tag of sanitized.strippedElements) addConsole(`  stripped <${tag}>`, "error");
			for (const attr of sanitized.strippedAttributes) addConsole(`  stripped ${attr.attribute} on <${attr.element}>`, "error");
		} else {
			addConsole("Fragment is clean", "log");
		}

		const slotEl = document.getElementById(`fwb-slot-${slotId.replace(/\./g, "-")}`);
		if (!slotEl) return;
		if (!slot.multiple) slotEl.innerHTML = "";

		const wrapper = document.createElement("div");
		wrapper.className = "fragment-wrapper";
		wrapper.innerHTML = sanitized.html;
		slotEl.appendChild(wrapper);
		applyDataBind(wrapper, state);
		applyDataIf(wrapper, state);
		mountedFragments.push({ container: wrapper, slotId });
		addConsole(`Mounted into ${slotId}`, "result");
		updateExportPreview();
	}

	function buildModManifest() {
		const editor = document.getElementById("fwb-editor");
		const slotSelect = document.getElementById("fwb-slot-select");
		const formatToggle = document.getElementById("fwb-format-toggle");
		const format = formatToggle.value === "jsml" ? "application/jsml+json" : "text/html";

		const mod = {
			xript: "0.4",
			name: "my-mod",
			version: "1.0.0",
			capabilities: [],
			fragments: [{
				id: "my-fragment",
				slot: slotSelect.value || "sidebar.left",
				format,
				inline: true,
				source: editor.value,
			}],
		};

		if (currentManifest?.slots) {
			const slot = currentManifest.slots.find(s => s.id === slotSelect.value);
			if (slot?.capability) mod.capabilities.push(slot.capability);
		}
		return mod;
	}

	function updateExportPreview() {
		const preview = document.getElementById("fwb-export-preview");
		const editor = document.getElementById("fwb-editor");
		if (!editor.value.trim()) {
			preview.innerHTML = '<span class="placeholder">Author a fragment to see your mod manifest here.</span>';
			return;
		}
		preview.textContent = JSON.stringify(buildModManifest(), null, "\t");
	}

	function exportModManifest() {
		const mod = buildModManifest();
		const blob = new Blob([JSON.stringify(mod, null, "\t")], { type: "application/json" });
		const url = URL.createObjectURL(blob);
		const a = document.createElement("a");
		a.href = url;
		a.download = "mod-manifest.json";
		a.click();
		URL.revokeObjectURL(url);
		addConsole("Exported mod manifest", "result");
	}

	function loadManifest(key) {
		const editor = document.getElementById("fwb-manifest-editor");
		const status = document.getElementById("fwb-manifest-status");

		if (key === "custom") {
			editor.readOnly = false;
			editor.value = JSON.stringify({ xript: "0.4", name: "my-app", slots: [] }, null, "\t");
			status.innerHTML = '<span class="status-info">Edit your manifest above</span>';
			currentManifest = null;
			return;
		}

		const manifest = exampleManifests[key];
		if (!manifest) return;

		editor.readOnly = true;
		editor.value = JSON.stringify(manifest, null, "\t");
		currentManifestKey = key;

		const result = validateManifest(manifest);
		if (result.valid) {
			status.innerHTML = '<span class="status-ok">\u2713 Valid manifest</span>';
			currentManifest = manifest;
			state = buildStateFromManifest(manifest);
			mountedFragments = [];
			renderSlotRegions();
			renderStateControls();
			renderSamples();
			if (manifest.slots?.[0]) {
				renderSlotContract(manifest.slots[0], "fwb-slot-contract");
				renderSlotContract(manifest.slots[0], "fwb-slot-contract-preview");
			}
		} else {
			status.innerHTML = `<span class="status-err">\u2717 ${result.errors.length} error(s)</span>`;
			currentManifest = null;
		}
	}

	function parseCustomManifest(json) {
		const status = document.getElementById("fwb-manifest-status");
		try {
			const manifest = JSON.parse(json);
			const result = validateManifest(manifest);
			if (result.valid) {
				status.innerHTML = '<span class="status-ok">\u2713 Valid manifest</span>';
				currentManifest = manifest;
				currentManifestKey = "custom";
				state = buildStateFromManifest(manifest);
				mountedFragments = [];
				renderSlotRegions();
				renderStateControls();
				renderSamples();
				if (manifest.slots?.[0]) {
					renderSlotContract(manifest.slots[0], "fwb-slot-contract");
					renderSlotContract(manifest.slots[0], "fwb-slot-contract-preview");
				}
			} else {
				status.innerHTML = `<span class="status-err">\u2717 ${result.errors.map(e => e.message).join("; ")}</span>`;
			}
		} catch {
			status.innerHTML = '<span class="status-err">\u2717 Invalid JSON</span>';
		}
	}

	function switchTab(tabId) {
		for (const btn of document.querySelectorAll("#fwb-tabs .tab")) {
			btn.classList.toggle("active", btn.dataset.tab === tabId);
		}
		for (const content of document.querySelectorAll(".tab-content")) {
			content.classList.toggle("active", content.id === `tab-${tabId}`);
		}
	}

	function boot() {
		try {
			document.getElementById("fwb-loading").style.display = "none";
			document.getElementById("fwb-main").style.display = "block";

			for (const btn of document.querySelectorAll("#fwb-tabs .tab")) {
				btn.addEventListener("click", () => switchTab(btn.dataset.tab));
			}

			for (const toggle of document.querySelectorAll(".guide-toggle")) {
				toggle.addEventListener("click", () => {
					const body = toggle.nextElementSibling;
					const arrow = toggle.querySelector(".guide-arrow");
					const key = toggle.dataset.guide;
					const open = body.style.display === "none";
					body.style.display = open ? "block" : "none";
					arrow.textContent = open ? "\u25be" : "\u25b8";
					guideStates[key] = open;
				});
			}

			const manifestSelect = document.getElementById("fwb-manifest-select");
			const manifestEditor = document.getElementById("fwb-manifest-editor");
			const sampleSelect = document.getElementById("fwb-sample-select");
			const formatToggle = document.getElementById("fwb-format-toggle");
			const editor = document.getElementById("fwb-editor");

			manifestSelect.addEventListener("change", () => loadManifest(manifestSelect.value));

			let debounce;
			manifestEditor.addEventListener("input", () => {
				if (manifestSelect.value !== "custom") return;
				clearTimeout(debounce);
				debounce = setTimeout(() => parseCustomManifest(manifestEditor.value), 500);
			});

			function loadSelectedSample(runDiag) {
				const sample = (sampleFragments[currentManifestKey] || [])[parseInt(sampleSelect.value)];
				if (!sample) return;
				editor.value = formatToggle.value === "jsml" && sample.jsml ? sample.jsml : sample.html;
				if (runDiag) runDiagnostics(sample.html);
				updateExportPreview();
			}

			sampleSelect.addEventListener("change", () => loadSelectedSample(true));
			formatToggle.addEventListener("change", () => loadSelectedSample(false));

			let editorDebounce;
			editor.addEventListener("input", () => {
				clearTimeout(editorDebounce);
				editorDebounce = setTimeout(() => {
					let html = editor.value;
					if (formatToggle.value === "jsml") {
						try { html = jsmlToHtml(JSON.parse(html)); } catch { return; }
					}
					runDiagnostics(html);
					updateExportPreview();
				}, 300);
			});

			document.getElementById("fwb-mount-btn").addEventListener("click", () => {
				let html = editor.value.trim();
				if (!html) return;
				if (formatToggle.value === "jsml") {
					try { html = jsmlToHtml(JSON.parse(html)); addConsole("Converted JSML to HTML", "log"); }
					catch (e) { addConsole(`Invalid JSML: ${e.message}`, "error"); return; }
				}
				mountFragment(html, document.getElementById("fwb-slot-select").value);
			});

			document.getElementById("fwb-clear-slots-btn").addEventListener("click", () => {
				for (const el of document.querySelectorAll("#fwb-host-slots .slot-content")) el.innerHTML = "";
				mountedFragments = [];
				addConsole("Cleared all slots", "log");
			});

			document.getElementById("fwb-clear-btn").addEventListener("click", () => {
				document.getElementById("fwb-console").innerHTML = '<div class="placeholder">Mount a fragment to see output here.</div>';
			});

			document.getElementById("fwb-export-btn").addEventListener("click", exportModManifest);

			loadManifest("dashboard");
			addConsole("Fragment Workbench ready", "log");
		} catch (err) {
			document.getElementById("fwb-loading").innerHTML = `<p style="color: #f87171;">Failed to load: ${err.message}</p>`;
		}
	}

	boot();
</script>

