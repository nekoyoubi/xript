{
	"$schema": "https://xript.dev/schema/mod-manifest/v0.6.json",
	"xript": "0.6",
	"name": "health-panel",
	"version": "1.0.0",
	"title": "Health Panel",
	"description": "Displays the player's health bar with low-health warnings.",
	"author": "xript-examples",
	"capabilities": ["ui-mount"],
	"entry": "src/mod.js",
	"fills": {
		"sidebar.left": [
			{
				"id": "health-display",
				"format": "text/html",
				"source": "fragments/panel.html",
				"bindings": [
					{ "name": "health", "path": "player.health" },
					{ "name": "maxHealth", "path": "player.maxHealth" },
					{ "name": "name", "path": "player.name" }
				],
				"priority": 10
			}
		]
	}
}
