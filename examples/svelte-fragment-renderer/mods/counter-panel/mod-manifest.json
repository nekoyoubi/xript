{
	"$schema": "https://xript.dev/schema/mod-manifest/v0.7.json",
	"xript": "0.7",
	"name": "counter-panel",
	"version": "1.0.0",
	"title": "Counter Panel",
	"description": "A click-to-increment counter panel demonstrating bindings, visibility, the command buffer, and declared fragment handlers.",
	"author": "xript-examples",
	"capabilities": ["ui-mount"],
	"entry": "src/mod.js",
	"fills": {
		"sidebar.left": [
			{
				"id": "counter-display",
				"format": "text/html",
				"source": "fragments/counter.html",
				"bindings": [
					{ "name": "value", "path": "counter.value" }
				],
				"handlers": [
					{ "selector": ".increment-btn", "on": "click", "handler": "onIncrement" }
				],
				"priority": 10
			}
		]
	}
}
