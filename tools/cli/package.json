{
	"name": "@xriptjs/cli",
	"version": "0.6.0",
	"description": "Unified CLI for the xript ecosystem — validate, generate types, generate docs, scaffold projects, sanitize fragments, scan annotations, run mods, and serve the same capabilities to agents over MCP.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"content"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/nekoyoubi/xript.git",
		"directory": "tools/cli"
	},
	"homepage": "https://xript.dev",
	"bin": {
		"xript": "./dist/cli.js"
	},
	"scripts": {
		"sync-content": "node scripts/sync-content.mjs",
		"build": "npm run sync-content && tsc",
		"test": "npm run sync-content && node --test test/*.test.js",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"xript",
		"cli",
		"toolchain",
		"modding",
		"extensibility"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"@xriptjs/docgen": "^0.6.0",
		"@xriptjs/init": "^0.6.0",
		"@xriptjs/runtime": "^0.6.0",
		"@xriptjs/sanitize": "^0.6.0",
		"@xriptjs/typegen": "^0.6.0",
		"@xriptjs/validate": "^0.6.0",
		"zod": "^3.23.8"
	},
	"optionalDependencies": {
		"ts-morph": "^25.0.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/node": "^22.0.0"
	}
}
