{
	"name": "@xriptjs/typegen",
	"version": "0.3.0",
	"description": "Generate TypeScript definitions from xript manifests.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"repository": {
		"type": "git",
		"url": "https://github.com/nekoyoubi/xript.git",
		"directory": "tools/typegen"
	},
	"homepage": "https://xript.dev",
	"bin": {
		"xript-typegen": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsc",
		"test": "node --test test/*.test.js",
		"prepublishOnly": "npm run build"
	},
	"keywords": ["xript", "typegen", "typescript", "code-generation"],
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/node": "^22.0.0"
	}
}
