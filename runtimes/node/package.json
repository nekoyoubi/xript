{
	"name": "@xriptjs/runtime-node",
	"version": "0.3.0",
	"description": "Node.js-optimized xript runtime — sandboxed script execution via Node.js vm module.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"repository": {
		"type": "git",
		"url": "https://github.com/nekoyoubi/xript.git",
		"directory": "runtimes/node"
	},
	"homepage": "https://xript.dev",
	"scripts": {
		"build": "tsc",
		"test": "node --test test/*.test.js",
		"prepublishOnly": "npm run build"
	},
	"keywords": ["xript", "runtime", "sandbox", "scripting", "modding", "node", "vm"],
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"@xriptjs/sanitize": "^0.3.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/node": "^22.0.0"
	}
}
