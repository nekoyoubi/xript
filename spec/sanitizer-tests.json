		"expected": "<img src=\"icon.png\" alt=\"health icon\" width=\"16\" height=\"16\" />",
		"description": "preserves img with safe src, alt, width, height"
	},
	{
		"input": "<a href=\"https://example.com\" target=\"_blank\" rel=\"noopener\">link</a>",
		"expected": "<a href=\"https://example.com\" target=\"_blank\" rel=\"noopener\">link</a>",
		"description": "preserves anchor with safe href, target, rel"
	},
	{
		"input": "<style>.warning { color: red; }</style><div class=\"warning\">alert</div>",
		"expected": "<style>.warning { color: red; }</style><div class=\"warning\">alert</div>",
