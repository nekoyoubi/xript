	},
	{
		"input": "<table><thead><tr><th scope=\"col\">Name</th></tr></thead><tbody><tr><td>Item</td></tr></tbody></table>",
		"expected": "<table><thead><tr><th scope=\"col\">Name</th></tr></thead><tbody><tr><td>Item</td></tr></tbody></table>",
